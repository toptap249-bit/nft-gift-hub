# Скопируй в .env и заполни значения

PORT=3000
NODE_ENV=development

# Токен бота из BotFather (https://t.me/BotFather, /newbot)
TELEGRAM_BOT_TOKEN=

# Authtoken для ngrok-туннеля (один раз — бесплатная регистрация):
# https://dashboard.ngrok.com/signup
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Опционально: если деплоишь на Render/Railway/Fly и не используешь ngrok,
# просто пропиши сюда публичный HTTPS-URL твоего хостинга.
# WEBAPP_URL=https://my-app.onrender.com
